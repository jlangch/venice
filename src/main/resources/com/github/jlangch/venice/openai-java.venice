;;;; OpenAI Java API module

;;;; OpenAI OpenAPI:  https://github.com/openai/openai-java


(ns openai-java)

(import :com.openai.client.OpenAIClient)
(import :com.openai.client.okhttp.OpenAIOkHttpClient)
(import :com.openai.models.ChatModel)
(import :com.openai.models.responses.Response)
(import :com.openai.models.responses.ResponseCreateParams)



;; -----------------------------------------------------------------------------
;; CHAT COMPLETIONS 
;; -----------------------------------------------------------------------------

(defn 
  ^{ :arglists '(
          "(chat-completion prompt & options)" )
     :doc """
          Runs a chat completion.

          To run the request asynchronously just wrap it in a `future` and
          deref it, when the result is required.

          ¶*Parameter request «options»*

          | [![width: 15%]]   | [![width: 85%]] |
          | :model m          | An OpenAI model. E.g.: :GPT_5_4, :GPT_5_4_MINI,\
                                :GPT_5_4_NANO. ¶\
                                Defaults to :GPT_5_4|
          | :openai-api-key k | An optional OpenAI API Key. As default the key \
                                is read from the environment variable \
                                "OPENAI_API_KEY". |
          | :openai-org-id k  | An optional OpenAI organisation ID. As default  \
                                the id is read from the environment variable  \
                                "OPENAI_ORG_ID". |
          | :openai-proj-id k | An optional OpenAI project ID. As default the id  \
                                is read from the environment variable  \
                                "OPENAI_PROJECT_ID". |

          ¶*Return value*

          Returns a map with the response data:*

          | [![width: 15%]] | [![width: 85%]] |
          | :status         | The response status { :completed, :failed, \
                              :in_progress, :cancelled, :queued, :incomplete,
                              :unknown }  |
          | :elapsed-millis | The elapsed milliseconds  |
          | :usage          | The usage data. E.g.:¶\
                              ``` ¶\  
                              { :input-tokens 11 ¶\
                                :output-tokens 8 ¶\
                                :output-tokens-detail { ¶\
                                  :reasoning-tokens 0 ¶\
                                 } ¶\
                                :total-tokens 19 ¶\
                              } ¶\
                              ```|
          | :output-msg     | A list of response output messages. E.g.:¶\
                              ``` ¶\  
                              [ { :status :completed  ¶\ 
                                  :content [ { :type :text  ¶\ 
                                               :content "The answer..." ¶\ 
                                             } ¶\ 
                                           ] ¶\ 
                                } ¶\ 
                              ] ¶\
                              ```|
          | :response       | The original response, a Java object of type \
                              `:com.openai.models.responses.Response` |
          """ 
     :examples '(
          """
          (do
            (load-module :openai-java)
            (-> (openai-java/chat-completion "Say this is a test" :model :GPT_5_4)
                (println)))
          """,
          """
          (do
            (load-module :openai-java)
            (let [prompt   "Say this is a test"
                  response (openai-java/chat-completion prompt :model :GPT_5_4)
                           ;; only first output item
                  result   (openai-java/get-first-output-msg response) 
                  usage    (:usage response)]
              (println "Status: " (:status response))
              (println)
              (println (openai-java/format-usage usage "  " "Tokens:"))
              (println)
              (println "Result: ")
              (println result)))
          """)
     :see-also '( ) }

  chat-completion [prompt & options]

  (let [opts          (apply hash-map options)
        model         (get opts :model :GPT_5_4)
                      ;; (. :OpenAIOkHttpClient :fromEnv)
        client        (create-ok-http-client opts)  
        start         (current-time-millis)
        params        (-> (. :ResponseCreateParams :builder)
                          (. :input prompt)
                          (. :model (. :ChatModel model))
                          (. :build))
        response      (-> (. client :responses)
                          (. :create params))
        elapsed       (- (current-time-millis) start)]
    (ordered-map  
      :status         (-> (. response :status)
                          (java-unwrap-optional :unknown)
                          (. :toString)
                          (keyword))
      :elapsed-millis elapsed
      :output-msg     (parse-response response)
      :usage          (response-usage-stats response)
      :response       response )))



;; -----------------------------------------------------------------------------
;; Utils
;; -----------------------------------------------------------------------------

(defn get-first-output-msg [response]
  (-> (:output-msg response)  ;; only first output item
      (first) 
      (get :content)
      (first)
      (get :content)))


(defn format-usage 
  ([usage]
    (format-usage usage nil nil))
  ([usage indent]
    (format-usage usage indent nil))
  ([usage indent title]
    (let [indent (coalesce indent "")
          title  (str/trim-to-nil title)]
      (str/format (str "%s"
                       "%sInput:  %5d%n"
                       "%sOutput: %5d (Reasoning: %d)%n"
                       "%sTotal:  %5d%n")
                  (if (nil? title) "" (str/format "%s%n" title))
                  indent (:input-tokens usage)
                  indent (:output-tokens usage) (:reasoning-tokens (:output-tokens-detail usage))
                  indent (:total-tokens usage)))))



;; -----------------------------------------------------------------------------
;; Internal Utils
;; -----------------------------------------------------------------------------

(defn- create-ok-http-client [opts]
  (when (exists-class? :com.openai.client.OpenAIClient) 
    throw (ex :VncException "The openai-java library is not available!"))

  (let [openai-api-key (or (:openai-api-key opts) (openai-api-key-from-env))
        openai-org-id  (or (:openai-org-id opts)  (openai-org-id-from-env))
        openai-proj-id (or (:openai-proj-id opts) (openai-proj-id-from-env))]
    (when (nil? openai-api-key)
      (throw (ex :VncException 
                 """
                 No OpenAI API key supplied. Pass the option ':openai-api-key key'
                 or set the environemt variable "OPENAI_API_KEY"!
                 """)))
    (let [builder (. :OpenAIOkHttpClient :builder)]
      (. builder :apiKey openai-api-key)
      (when (some? openai-org-id) (. builder :organization openai-org-id))
      (when (some? openai-proj-id) (. builder :project openai-proj-id))
      (. builder :build))))


(defn- response-usage-stats [response]
  (if-let [usage (java-unwrap-optional (. response :usage))]
    (let [output-details (. usage :outputTokensDetails)]
      (ordered-map 
        :input-tokens  (. usage :inputTokens)
        :output-tokens (. usage :outputTokens)
        :output-tokens-detail { :reasoning-tokens (. output-details :reasoningTokens) }
        :total-tokens  (. usage :totalTokens)))
    {}))


(defn- parse-response [response]
  (->> (. response :output)
       (map #(. % :message))
       (map #(java-unwrap-optional %))
       (filter some?)
       (map #(response-output-message %))
       (into [])))


(defn- response-output-message [out-msg]
  { :content  (->> (into [] (. out-msg :content))
                   (map #(. % :outputText))
                   (map #(java-unwrap-optional %))
                   (filter some?)
                   (map #(ordered-map :type :text  :content (. % :text)))
                   (into []))
    :status   (-> (. out-msg :status) ;; {:in_progress, :completed, :incomplete}
                  (. :toString)
                  (keyword))
  })


(defn- openai-api-key-from-env [] 
  (system-env "OPENAI_API_KEY"))

(defn- openai-org-id-from-env [] 
  (system-env "OPENAI_ORG_ID"))

(defn- openai-proj-id-from-env [] 
  (system-env "OPENAI_PROJECT_ID"))
