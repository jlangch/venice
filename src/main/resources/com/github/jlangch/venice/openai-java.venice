;; -----------------------------------------------------------------------------
;; CLIENT 
;; -----------------------------------------------------------------------------

(defn 
  ^{ :arglists '(
          "(client & options)" )
     :doc """
          Creates an OpenAI client.

          **Note:**

          Don’t create more than one client in the same application. Each client 
          has a connection pool and thread pools, which are more efficient to 
          share between requests.

          ¶**Parameter «options»**

          | [![width: 15%]]    | [![width: 85%]] |
          | :openai-api-key k  | An optional OpenAI API Key. As fallback the key \
                                 is read from the environment variable \
                                 "OPENAI_API_KEY". |
          | :openai-org-id k   | An optional OpenAI organisation ID. As fallback \
                                 the id is read from the environment variable \
                                 "OPENAI_ORG_ID". |
          | :openai-proj-id k  | An optional OpenAI project ID. As fallback the id \
                                 is read from the environment variable  \
                                 "OPENAI_PROJECT_ID". |
          | :openai-base-url u | An optional OpenAI baseURL. As fallback the url \
                                 is read from the environment variable  \
                                 "OPENAI_BASE_URL". ¶\
                                 OpenAI uses the standard base URL \
                                 'https://api.openai.com/v1' if it is not \
                                 explicitely defined. |

          ¶**Install OpenAI Java libraries in the REPL**

          ```
          (do
            (load-module :openai-java-install)
            (openai-java-install/install :dir (repl/libs-dir) :silent false))
          ```

          Restart the REPL after installing the libraries!
          """ 
     :examples '(
          """
          (do
            (load-module :openai-java)
            (let [client (openai-java/client)]
              ;; ...
              (openai-java/close client)))
          """,
          """
          (do
            (load-module :openai-java)
            (let [client (openai-java/client :openai-api-key "sk-1234")]
              ;; ...
              (openai-java/close client)))
          """)
     :see-also '(
        "openai-java/version"
        "openai-java/close"
        "openai-java/chat-completion"
        "openai-java/generate-image"
        "openai-java/create-speech") }

  client [& options]

  (validate-libs-installed)

  (let [opts            (apply hash-map options)
        openai-api-key  (or (:openai-api-key opts)  (openai-api-key-from-env))
        openai-org-id   (or (:openai-org-id opts)   (openai-org-id-from-env))
        openai-proj-id  (or (:openai-proj-id opts)  (openai-proj-id-from-env))
        openai-base-url (or (:openai-base-url opts) (openai-base-url-from-env))]
    (when (nil? openai-api-key)
      (throw (ex :VncException 
                 """
                 No OpenAI API key supplied. Pass the option ':openai-api-key key'
                 or set the environemt variable "OPENAI_API_KEY"!
                 """)))
    (let [builder (. :OpenAIOkHttpClient :builder)]
      (. builder :apiKey openai-api-key)
      (when (some? openai-org-id)   (. builder :organization openai-org-id))
      (when (some? openai-proj-id)  (. builder :project openai-proj-id))
      (when (some? openai-base-url) (. builder :baseUrl openai-base-url))
      (. builder :build))))


(defn 
  ^{ :arglists '(
          "(close client)" )
     :doc """
          Closes an OpenAI client.
          """ 
     :examples '(
          """
          (do
            (load-module :openai-java)
            (let [client (openai-java/client)]
              ;; ...
              (openai-java/close client)))
          """,)
     :see-also '(
          "openai-java/client") }

  close [client]

  { :pre [(instance-of? :OpenAIClient client)] }

  (. client :close))



;; -----------------------------------------------------------------------------
;; CHAT COMPLETION REQUEST
;; -----------------------------------------------------------------------------

(defn 
  ^{ :arglists '(
          "(chat-completiont client model)" )
     :doc """
          Defines a OpenAI chat completion request.

          It serves as a OpenAI chat completion conversation.

          ¶**Argument**

          | [![width: 15%]]     | [![width: 85%]] |
          | client | A client. ¶\
                     Use `openai-java/client` to create a client|
          | model  | An OpenAI model. E.g.: `:GPT_5_4`, `:GPT_5_4_MINI`, \
                     `:GPT_5_4_NANO`|

          Returns the chat completion result

          [OpenAI Text Prompting Guide](https://developers.openai.com/cookbook/examples/gpt-5/gpt-5_prompting_guide)
          [OpenAI Text Cookbook](https://developers.openai.com/cookbook/topic/text)
          """
     :examples '(
          """
          (do
            (load-module :openai-java)
            (let [client   (openai-java/client)
                  chat     (-> (openai-java/chat-completion client :GPT_5_4)
                               (openai-java/max-completion-tokens 2048)
                               (openai-java/add-user-message "Say this is a test"))
                  response (openai-java/execute chat)
                  msg      (first (openai-java/messages response))]
              (println msg)))
          """,
          """
          (do
            (load-module :openai-java)
            (let [client   (openai-java/client)
                  chat     (-> (openai-java/chat-completion client :GPT_5_4)
                               (openai-java/max-completion-tokens 2048)
                               (openai-java/add-user-message "Say this is a test"))
                  response (openai-java/execute chat)
                  elapsed  (openai-java/elapsed chat)
                  usage    (openai-java/usage response)
                  msg      (first (openai-java/messages response))]
              (printf "Elapsed: %dms%n%n" elapsed)
              (printf "Tokens:  %n%s%n" (openai-java/format-usage usage "  "))
              (printf "Result:  %n%s%n" msg)))
          """,
          """
          ;; conversation
          (do
            (load-module :openai-java)
            (let [client   (openai-java/client)
                  chat     (-> (openai-java/chat-completion client :GPT_5_4)
                               (openai-java/max-completion-tokens 2048)
                               (openai-java/add-user-message "Say Hello!"))
                  response (openai-java/execute chat)]
              (println (first (openai-java/messages response)))
              ;; 1st follow up question
              (openai-java/add-assistant-message chat (openai-java/messages response))      
              (openai-java/add-user-message chat "Can you say it more informal?")
              (let [response (openai-java/execute chat)]
                (println (first (openai-java/messages response))))
              ;; 2nd follow up question
              (openai-java/add-assistant-message chat (openai-java/messages response))      
              (openai-java/add-user-message chat "Can you say it very formal?")
              (let [response (openai-java/execute chat)]
                (println (first (openai-java/messages response))))))
          """,
          """
          ;; structured output
          (do
            (load-module :openai-java)
            (let [client   (openai-java/client)
                  chat     (-> (openai-java/chat-completion client :GPT_5_4)
                               (openai-java/max-completion-tokens 2048)
                               (openai-java/json-response-format 
                                    "employee-list"
                                    "A list of employees"
                                    "object"
                                    { :employees { :items  { "type" "string" }}} )
                               (openai-java/add-user-message "Who works at OpenAI?"))
                  response (openai-java/execute chat)
                  msg      (first (openai-java/messages response))]
              (println (first (openai-java/messages response)))))
          """,
          """
          ;; function call
          (do
            (load-module :openai-java)

            (defn celsius-to-fahrenheit [c]
              (-> (double c) (* 9) (/ 5) (+ 32) (long)))  ;; (c * 9) / 5 + 32

            (defn degrees [t unit]
              (if (str/equals-ignore-case? unit "celsius") t (celsius-to-fahrenheit t)))

            (defn get-weather [fnArgsJson]
              (let [args     (json/read-str fnArgsJson)
                    location (get args "location")
                    unit     (get args "unit")]
                (cond                 ;; we just support one hard coded location
                  (str/contains? location "Zurich")
                    (json/write-str { :location    location
                                      :unit        unit
                                      :temperature (degrees 21 unit)
                                      :conditions  "Mostly sunny" })
                  :else
                    (json/write-str { :location location
                                      :error    (str "No weather data available for " location "!")}))))

            (let [client   (openai-java/client)
                  registry (-> (openai-java/create-function-registry)
                               (openai-java/register-function "GetWeather"
                                                              get-weather))
                  chat     (-> (openai-java/chat-completion client :GPT_5_4 registry)
                               (openai-java/max-completion-tokens 2048)
                               (openai-java/debug false)
                               (openai-java/add-function 
                                    "GetWeather"
                                    "Gets the current weather for a city."
                                    { :location { 
                                        :type "string" 
                                        :description "A city, e.g.: Zurich" }
                                      :unit { 
                                        :type "string"
                                        :description "Temperature unit: celsius or fahrenheit" } } 
                                    [ "location" "unit" ])
                               (openai-java/add-user-message "What is the weather in Zurich in Celsius?"))
                  response (openai-java/execute chat)]
              (println (coalesce (first (openai-java/messages response)) "<no message>\n"))
              ;; follow up question
              (openai-java/add-assistant-message chat (openai-java/messages response))      
              (openai-java/add-user-message chat "Please give the current weather in Zurich and some ideas what to do in Zurich on day like this!")
              (let [response (openai-java/execute chat)]
                (println (first (openai-java/messages response))))))
          """)
     :see-also '(
          "openai-java/max-completion-tokens"
          "openai-java/json-response-format"
          "openai-java/add-function"
          "openai-java/add-user-message"
          "openai-java/add-assistant-message"
          "openai-java/execute"
          "openai-java/client"
          "openai-java/close"
          "openai-java/format-usage") }

  chat-completion 
  
  ([client model]
    { :pre [(validate-libs-installed) 
            (instance-of? :OpenAIClient client) 
            (keyword? model)] }
    (. :ChatCompletionTraditionalRequest :of client (. :ChatModel model)))
  
  ([client model fn-registry]
    { :pre [(validate-libs-installed) 
            (instance-of? :OpenAIClient client) 
            (keyword? model)] }
    (. :ChatCompletionTraditionalRequest :of client (. :ChatModel model) fn-registry)))


(defn 
  ^{ :arglists '(
          "(max-completion-tokens chat tokens)" )
     :doc """
          Sets the max completion tokens OpenAI must use. 'tokens' must be
          positive number.

          Returns the chat.
          """
     :see-also '(
        "openai-java/chat-completion") }

  max-completion-tokens [chat tokens]
  
  { :pre [(instance-of? :ChatCompletionTraditionalRequest chat) (long? tokens)] }
  (. chat :maxCompletionTokens tokens))


(defn debug [chat on]
  { :pre [(instance-of? :ChatCompletionTraditionalRequest chat) (boolean? on)] }
  (. chat :debug on))

(defn 
  ^{ :arglists '(
          "(add-user-message chat msg)" )
     :doc """
          Adds a *user* message or a list of *user* messages to the chat
          completion request.

          Returns the chat.
          """
     :see-also '(
        "openai-java/chat-completion") }

  add-user-message [chat msg]
  
  { :pre [(instance-of? :ChatCompletionTraditionalRequest chat) 
          (or (string? msg) (sequential? msg))] }
  (if (string? msg)
    (. chat :addUserMessage (filter-msgs msg))
    (. chat :addUserMessages (filter-msgs msg))))


(defn 
  ^{ :arglists '(
          "(add-user-message-with-files chat msg & file-objects)" )
     :doc """
          Adds a *user* message with additional file objects to the chat
          completion request.

          Returns the chat.
          """
     :examples '(
          """
          (do
            (load-module :openai-java)
            
            (let [client   (openai-java/client)
                  file-obj (openai-java/create-file-object 
                                          client 
                                          (io/file "/Users/foo/Desktop/Tour_Eiffel.pdf")
                                          :USER_DATA
                                          3600)
                  chat     (-> (openai-java/chat-completion client :GPT_5_4)
                               (openai-java/max-completion-tokens 2048)
                               (openai-java/add-user-message-with-files 
                                    "Describe this image"
                                    file-obj))
                  response (openai-java/execute chat)
                  elapsed  (openai-java/elapsed chat)
                  usage    (openai-java/usage response)
                  msg      (first (openai-java/messages response))]
              (printf "Elapsed: %dms%n%n" elapsed)
              (printf "Tokens:  %n%s%n" (openai-java/format-usage usage "  "))
              (printf "Result:  %n%s%n" msg)))
          """)
     :see-also '(
        "openai-java/create-file-object"
        "openai-java/create-file-object-binary"
        "openai-java/chat-completion") }

  add-user-message-with-files [chat msg & file-objects]

  { :pre [(instance-of? :ChatCompletionTraditionalRequest chat) 
          (or (string? msg) (sequential? msg))] }
  (. chat :addUserMessageWithFiles msg file-objects))


(defn 
  ^{ :arglists '(
          "(add-assistant-message chat msg)" )
     :doc """
          Adds an *assistant* message or a list of *assistant* messages to the 
          chat completion request.

          Returns the chat.
          """
     :see-also '(
        "openai-java/chat-completion") }

  add-assistant-message [chat msg]
  
  { :pre [(instance-of? :ChatCompletionTraditionalRequest chat) 
          (or (string? msg) (sequential? msg))] }
  (if (string? msg)
    (. chat :addAssistantMessage (filter-msgs msg))
    (. chat :addAssistantMessages (filter-msgs msg))))

(defn add-system-message [chat msg]
  { :pre [(instance-of? :ChatCompletionTraditionalRequest chat) 
          (or (string? msg) (sequential? msg))] }
  (if (string? msg)
    (. chat :addSystemMessage (filter-msgs msg))
    (. chat :addSystemMessages (filter-msgs msg))))

(defn add-developer-message [chat msg]
  { :pre [(instance-of? :ChatCompletionTraditionalRequest chat) 
          (or (string? msg) (sequential? msg))] }
  (if (string? msg)
    (. chat :addDeveloperMessage (filter-msgs msg))
    (. chat :addDeveloperMessages (filter-msgs msg))))


(defn 
  ^{ :arglists '(
          "(add-function chat name description properties required)"
          "(add-function chat name description type properties required)" )
     :doc """
          Add a function definition to a chat. Any number of function definitions
          can be added to a chat.

          Returns the chat.
          """
     :examples '(
          """
          (do
            (load-module :openai-java)

            (let [client   (openai-java/client)
                  chat     (-> (openai-java/chat-completion client :GPT_5_4)
                               (openai-java/add-function 
                                    "GetWeather"
                                    "Gets the current weather for a city."
                                    "object"
                                    { :location { 
                                        :type "string" 
                                        :description "A city, e.g.: Zurich" }
                                      :unit { 
                                        :type "string"
                                        :description "Temperature unit: celsius or fahrenheit" } } 
                                    [ "location" "unit" ]))]
                ;; ...
              ))
          """ )

     :see-also '(
        "openai-java/chat-completion") }

  add-function

  ([chat name description properties required]
    { :pre [(instance-of? :ChatCompletionTraditionalRequest chat)
            (string? name) (string? description) 
            (map? properties) (sequential? required)] }
    (. chat :addFunction name description "object" properties required))

  ([chat name description type properties required]
    { :pre [(instance-of? :ChatCompletionTraditionalRequest chat)
            (string? name) (string? description) (string? type)
            (map? properties) (sequential? required)] }
    (. chat :addFunction name description type properties required)))


(defn 
  ^{ :arglists '(
          "(json-response-format chat name description type properties)" )
     :doc """
          Sets a structured JSON response format

          Returns the chat.
          """
     :examples '(
          """
          (do
            (load-module :openai-java)

            (let [client   (openai-java/client)
                  chat     (-> (openai-java/chat-completion client :GPT_5_4)
                               (openai-java/json-response-format 
                                    "employee-list"
                                    "A list of employees"
                                    "object"
                                    { :employees { :items  { "type" "string" }}} )
                               (openai-java/add-user-message ""Who works at OpenAI?""))]
              ;; ...
              ))
          """ )
     :see-also '(
        "openai-java/chat-completion") }

  json-response-format [chat name description type properties]

  { :pre [(instance-of? :ChatCompletionTraditionalRequest chat)
          (string? name) (string? description) (string? type) (map? properties)] }
  (. chat :jsonResponseFormat name description type properties))


(defn 
  ^{ :arglists '(
          "(execute chat)" )
     :doc """
          Execute (send) a chat completion. Returns an OpenAI response.

          Return the chat.
          """
     :see-also '(
        "openai-java/chat-completion") }

  execute [chat]

  { :pre [(instance-of? :ChatCompletionTraditionalRequest chat)] }
  (. chat :execute))


(defn
  ^{ :arglists '(
          "(messages response)" )
     :doc """
          Returns a list of messages of the response.
          """
     :see-also '(
        "openai-java/chat-completion") }

  messages [response]

  { :pre [(instance-of? :ChatCompletionTraditionalResponse response)] }
  (. response :getMessages))


(defn elapsed [chat]
  { :pre [(instance-of? :ChatCompletionTraditionalRequest chat)] }
  (. chat :elapsed))



;; -----------------------------------------------------------------------------
;; Files
;; -----------------------------------------------------------------------------

(defn
  ^{ :arglists '(
          "(create-file-object client file)"
          "(create-file-object client file purpose)"
          "(create-file-object client file expires-after-seconds)" )
     :doc """
          Creates a new OpenAI file object.

          Arguments:

          | [![width: 15%]]       | [![width: 85%]] |
          | client                | An OpenAI client |
          | file                  | A file path. E.g.: (io/file "/data/planning.pdf") |
          | purpose               | A purpose: `:USER_DATA`, `:VISION`, `:BATCH`, \
                                    `:ASSISTANTS`, `:FINE_TUNE` |
          | expires-after-seconds | The file object expiry time in seconds. \
                                    A negative value means no expiration. ¶\
                                    Defaults to 3600s |

          Supported file types:

          | PDF files	      | `.pdf` |
          | Text and code   | `.txt`, `.md`, `.json`, `.html`, `.xml`, code files |
          | Rich documents	| `.doc`, `.docx`, `.rtf`, `.odt` |
          | Presentations	  | `.ppt`, `.pptx` |
          | Spreadsheets	  | `.csv`, `.xls`, `.xlsx` |

          Returns the file object `:com.openai.models.files.FileObject`.
          """
     :see-also '(
          "openai-java/create-file-object-binary"
          "openai-java/add-user-message-with-files"
          "openai-java/client") }

  create-file-object 
  
  ([client file]
    (create-file-object client file :USER_DATA 3600))
  
  ([client file purpose]  
    (create-file-object client file purpose 3600))
  
  ([client file purpose expires-after-seconds] 
    { :pre [(instance-of? :OpenAIClient client) 
            (io/file? file)
            (keyword? purpose) 
            (long? expires-after-seconds)] }
    (when-not (io/exists-file? file)
      (throw (ex :VncException "The file ~{file} does not exist")))
    (. :FileObjects :fileObject client 
                                file
                                (. :FilePurpose purpose) 
                                expires-after-seconds)))


(defn
  ^{ :arglists '(
          "(create-file-object-binary client data filename)"
          "(create-file-object-binary client data filename purpose)"
          "(create-file-object-binary client data filename expires-after-seconds)" )
     :doc """
          Creates a new OpenAI binary file object.

          Arguments:

          | [![width: 15%]]       | [![width: 85%]] |
          | client                | An OpenAI client |
          | data                  | A data `bytebuf` |
          | filename              | A filename. E.g.: "planning.pdf" |
          | purpose               | A purpose: `:USER_DATA`, `:VISION`, `:BATCH`, \
                                    `:ASSISTANTS`, `:FINE_TUNE` |
          | expires-after-seconds | The file object expiry time in seconds. \
                                    A negative value means no expiration. ¶\
                                    Defaults to 3600s |

          Supported file types:

          | PDF files	      | `.pdf` |
          | Text and code   | `.txt`, `.md`, `.json`, `.html`, `.xml`, code files |
          | Rich documents	| `.doc`, `.docx`, `.rtf`, `.odt` |
          | Presentations	  | `.ppt`, `.pptx` |
          | Spreadsheets	  | `.csv`, `.xls`, `.xlsx` |

          Returns the file object `:com.openai.models.files.FileObject`.
          """
     :see-also '(
          "openai-java/create-file-object"
          "openai-java/add-user-message-with-files"
          "openai-java/client") }

  create-file-object-binary 
  
  ([client data filename]
    (create-file-object-binary client data filename :USER_DATA 3600))
  
  ([client data filename purpose]  
    (create-file-object client data filename purpose 3600))
  
  ([client data filename purpose expires-after-seconds] 
    { :pre [(instance-of? :OpenAIClient client) 
            (bytebuf? data)
            (string? filename)
            (keyword? purpose) 
            (long? expires-after-seconds)] }
    (try-with [tmp (. :TemporaryFile :of data filename)] 
      (. :FileObjects :fileObject client 
                                  (. tmp :getPath)  
                                  (. :FilePurpose purpose) 
                                   expires-after-seconds)
      (catch :Exception e 
         (trow (ex :VncException "Failed to create temporary file" e))))))


(defn 
  ^{ :arglists '(
          "(list-files client)"
          "(list-files client limit)" )
     :doc """
          List the files stored at OpenAI.

          Returns a list of file-object maps
          """
     :examples '(
          """
          (do
            (load-module :openai-java)

            (let [client  (openai-java/client)]
              (->> (openai-java/list-files client)
                   (docoll #(prn %)))))
          """ )
     :see-also '(
        "openai-java/create-file"
        "openai-java/create-binary-file"
        "openai-java/retrieve-file"
        "openai-java/delete-file"
        "openai-java/client") }

  list-files 

  ([client]
    { :pre [(instance-of? :OpenAIClient client)] }
    (-<> (. client :files)
         (. <> :list)
         (. <> :items)
         (map file-object->map <>)))
  
  ([client limit]
    { :pre [(instance-of? :OpenAIClient client) (long? limit)] }
    (let [params  (. :FileListParams :builder)]
      (. params :limit limit)
      (-<> (. client :files)
           (. <> :list (. params :build))
           (. <> :items)
           (map file-object->map <>)))))


(defn 
  ^{ :arglists '(
          "(retrieve-file client id)" )
     :doc """
          Retrieve the info of file stored at OpenAI

          Returns a file-object map
          """
     :examples '(
          """
          (do
            (load-module :openai-java)

            (let [client  (openai-java/client)]
              (openai-java/retrieve-file client "...file-id...")))
          """ )
     :see-also '(
          "openai-java/list-files"
          "openai-java/create-file"
          "openai-java/create-binary-file"
          "openai-java/delete-file"
          "openai-java/client") }

  retrieve-file [client id]

  { :pre [(instance-of? :OpenAIClient client) (string? id)] }

  (-<> (. client :files) 
       (. <> :retrieve id)
       (file-object->map <>)))


(defn 
  ^{ :arglists '(
          "(create-file client file)"
          "(create-file client file purpose)"
          "(create-file client file expires-after-seconds)" )
     :doc """
          Create an OpenAI file

          Arguments:

          | [![width: 15%]]       | [![width: 85%]] |
          | client                | An OpenAI client |
          | data                  | A data `bytebuf` |
          | filename              | A filename. E.g.: "planning.pdf" |
          | purpose               | A purpose: `:USER_DATA`, `:VISION`, `:BATCH`, \
                                    `:ASSISTANTS`, `:FINE_TUNE` |
          | expires-after-seconds | The file object expiry time in seconds. \
                                    A negative value means no expiration. ¶\
                                    Defaults to 3600s |

          Supported file types:

          | PDF files	      | `.pdf` |
          | Text and code   | `.txt`, `.md`, `.json`, `.html`, `.xml`, code files |
          | Rich documents	| `.doc`, `.docx`, `.rtf`, `.odt` |
          | Presentations	  | `.ppt`, `.pptx` |
          | Spreadsheets	  | `.csv`, `.xls`, `.xlsx` |

          Returns the file object.
          """
     :examples '(
          """
          (do
            (load-module :openai-java)

            (let [client  (openai-java/client)
                  file    (io/file "/Users/foo/Desktop/Tour_Eiffel.pdf")]
              (openai-java/create-file client file :USER_DATA 3600)))
          """ )
     :see-also '(
          "openai-java/list-files"
          "openai-java/create-binary-file"
          "openai-java/retrieve-file"
          "openai-java/delete-file"
          "openai-java/client") }

  create-file

  ([client file]
    (create-file client file :USER_DATA 3600))
  
  ([client file purpose]  
    (create-file client file purpose 3600))
  
  ([client file purpose expires-after-seconds] 
    { :pre [(instance-of? :OpenAIClient client) 
            (io/file? file)
            (keyword? purpose) 
            (long? expires-after-seconds)] }
    (when-not (io/exists-file? file)
      (throw (ex :VncException "The file ~{file} does not exist")))

    (let [params (. :FileCreateParams :builder)]
      (. params :file (io/->path file))
      (. params :expiresAfter (-> (. :FileCreateParams$ExpiresAfter :builder)
                                  (. :seconds expires-after-seconds)
                                  (. :build)))
      (. params :purpose (. :FilePurpose purpose))

      (-<> (. client :files)
           (. <> :create (. params :build))
           (file-object->map <>)))))


(defn 
  ^{ :arglists '(
          "(create-binary-file client data filename)"
          "(create-binary-file client data filename purpose)"
          "(create-binary-file client data filename expires-after-seconds)" )
     :doc """
          Create a binary OpenAI file

          Arguments:

          | [![width: 15%]]       | [![width: 85%]] |
          | client                | An OpenAI client |
          | data                  | A data `bytebuf` |
          | filename              | A filename. E.g.: "planning.pdf" |
          | purpose               | A purpose: `:USER_DATA`, `:VISION`, `:BATCH`, \
                                    `:ASSISTANTS`, `:FINE_TUNE` |
          | expires-after-seconds | The file object expiry time in seconds. \
                                    A negative value means no expiration. ¶\
                                    Defaults to 3600s |

          Supported file types:

          | PDF files	      | `.pdf` |
          | Text and code   | `.txt`, `.md`, `.json`, `.html`, `.xml`, code files |
          | Rich documents	| `.doc`, `.docx`, `.rtf`, `.odt` |
          | Presentations	  | `.ppt`, `.pptx` |
          | Spreadsheets	  | `.csv`, `.xls`, `.xlsx` |

          Returns the file object.
          """
     :examples '(
          """
          (do
            (load-module :openai-java)

            (let [client   (openai-java/client)
                  data     (bytebuf-from-string "Hello") 
                  filename "demo.md"]
              (openai-java/create-binary-file client 
                                              data filename 
                                              :USER_DATA 3600)))
          """ )
     :see-also '(
          "openai-java/list-files"
          "openai-java/create-file"
          "openai-java/retrieve-file"
          "openai-java/delete-file"
          "openai-java/client") }

  create-binary-file

  ([client data filename]
    (create-binary-file client data filename :USER_DATA 3600))
  
  ([client data filename purpose]  
    (create-binary-file client data filename purpose 3600))
  
  ([client data filename purpose expires-after-seconds] 
    { :pre [(instance-of? :OpenAIClient client) 
            (bytebuf? data)
            (string? filename)
            (keyword? purpose) 
            (long? expires-after-seconds)] }
    (try-with [tmp (. :TemporaryFile :of data filename)] 
      (let [params (. :FileCreateParams :builder)]
        (. params :file (. tmp :getPath))
        (. params :expiresAfter (-> (. :FileCreateParams$ExpiresAfter :builder)
                                    (. :seconds expires-after-seconds)
                                    (. :build)))
        (. params :purpose (. :FilePurpose purpose))

        (-<> (. client :files)
             (. <> :create (. params :build))
             (file-object->map <>)))
      (catch :Exception e 
        (throw (ex :VncException "Failed to create binary OpenAI file" e))))))


(defn 
  ^{ :arglists '(
          "(delete-file client id)" )
     :doc """
          Delete a file stored at OpenAI

          Returns `true` if the files could be deleted else `false`
          """
     :examples '(
          """
          (do
            (load-module :openai-java)

            (let [client  (openai-java/client)]
              (openai-java/delete-file client "...file-id...")))
          """ )
     :see-also '(
          "openai-java/list-files"
          "openai-java/create-file"
          "openai-java/create-binary-file"
          "openai-java/retrieve-file"
          "openai-java/client") }

  delete-file [client id]

  { :pre [(instance-of? :OpenAIClient client) (string? id)] }

  (-> (. client :files) 
      (. :delete id)
      (. :deleted)))


(defn 
  ^{ :arglists '(
          "(file-object->map file-object)" )
     :doc """
          Convert an OpenAI :FileObject to a map
          """
     :see-also '(
          "openai-java/client") }

  file-object->map [file-object]

  { :pre [(instance-of? :FileObject file-object)] }

  (ordered-map
    :id        (. file-object :id)
    :filename  (. file-object :filename)
    :purpose   (. file-object :purpose)
    :bytes     (. file-object :bytes)
    :createdAt (. file-object :createdAt)
    :expiresAt (java-unwrap-optional (. file-object :expiresAt) -1)
    :valid?    (. file-object :isValid)))



;; -----------------------------------------------------------------------------
;; IMAGES
;; -----------------------------------------------------------------------------

(defn 
  ^{ :arglists '(
          "(generate-image client model prompt & options)" )
     :doc """
          Generates an image.

          ¶**Parameters**

          | [![width: 15%]] | [![width: 85%]] |
          | :client c   | A client.¶ Use `openai-java/client` to create a client |
          | :model m    | The model to use for image generation. One of \
                          `:DALL_E_2`, `:DALL_E_3`, or a GPT image model (`:GPT_IMAGE_1`, \
                          `:GPT_IMAGE_1_MINI`, `:GPT_IMAGE_1_5`, or `:GPT_IMAGE_2`). \
                          Defaults to `:DALL_E_2` unless a parameter specific to \
                          the GPT image models is used.|
          | :prompt p   | A text description of the desired image(s). The maximum \
                          length is 32000 characters for the GPT image models, 1000 \
                          characters for dall-e-2 and 4000 characters for dall-e-3. |


          ¶**Parameter «options»**

          | [![width: 15%]] | [![width: 85%]] |
          | :background b   | Allows to set transparency for the background of the \
                              generated image(s). This parameter is only supported \
                              for GPT image models that support transparent backgrounds. \
                              Must be one of transparent, opaque, or auto (default value). \
                              When `:AUTO` is used, the model will automatically determine \
                              the best background for the image.¶\
                              `:GPT-IMAGE-2` does not support transparent backgrounds. \
                              Requests with background set to transparent will return an \
                              error for these models; use opaque or auto instead.¶\
                              If transparent, the output format needs to support transparency, \
                              so it should be set to either `:PNG` (default value) or `:WEBP`. |
          | :number n       | The number of images to generate. Must be between 1 and 10. For \
                              `:DALL_E_3`, only `n=1` is supported.¶\
                              minimum: 1, maximum: 10 |
          | :compression c  | The compression level (0-100%) for the generated images. This \
                              parameter is only supported for the GPT image models with the \
                              `:WEBP` or `:JPEG` output formats, and defaults to 100. |
          | :format f       | The format in which the generated images are returned. \
                              This parameter is only supported for the GPT image models. \
                              Must be one of `:PNG`, `:JPEG`, or `:WEBP`.  |
          | :quality f      | The quality of the image that will be generated.¶\
                              \u00A0 • `:AUTO` (default value) will automatically select the \
                              best quality for the given model.¶\
                              \u00A0 • `:HIGH`, `:MEDIUM` and `:LOW` are supported for the \
                              GPT image models.¶\
                              \u00A0 • `:HD` and `:STANDARD` are supported for `:DALL_E_3`.¶\
                              \u00A0 • `:STANDARD`is the only option for `:DALL_E_2`. |
          | :size f         | The size of the generated images.¶\
                              For `:GPT_IMAGE_2`, arbitrary resolutions are supported as \
                              WIDTHxHEIGHT strings, for example `1536x864`. Width and height \
                              must both be divisible by 16 and the requested aspect ratio \
                              must be between 1:3 and 3:1. Resolutions above `2560x1440` \
                              are experimental, and the maximum supported resolution is \
                              `3840x2160`. The requested size must also satisfy the model’s \
                              current pixel and edge limits. The standard sizes `1024x1024`, \
                              `1536x1024`, and `1024x1536` are supported by the GPT image models; \
                              auto is supported for models that allow automatic sizing. \
                              For `:DALL_E_2`, use one of `256x256`, `512x512`, or `1024x1024`. \
                              For `:DALL_E_3`, use one of `1024x1024`, `1792x1024`, or `1024x1792`. |
          | :style f        | The style of the generated images. This parameter is only \
                              supported for `:DALL_E_3`. Must be one of `:VIVID` or `:NATURAL`. \
                              Vivid causes the model to lean towards generating hyper-real \
                              and dramatic images. Natural causes the model to produce \
                              more natural, less hyper-real looking images. |
          | :response-format f | The format in which generated images with `:DALL_E_2` \
                                 and `:DALL_E_3` are returned. Must be one of `:URL` or `:B64_JSON`. \
                                 URLs are only valid for 60 minutes after the image has been \
                                 generated. This parameter isn’t supported for the GPT image \
                                 models, which always return base64-encoded images.|

          Returns an OpenAI image response

          [OpenAI Image Prompting Guide](https://developers.openai.com/cookbook/examples/multimodal/image-gen-models-prompting-guide)
          """ 
     :examples '(
          """
          (do
            (load-module :openai-java)
            (let [client   (openai-java/client)
                  response (openai-java/generate-image 
                                client 
                                :GPT_IMAGE_1_MINI
                                "A cat on bicycle"
                                :format :PNG
                                :number 1
                                :size "1024x1024")
                  usage    (openai-java/usage response)
                  image-1  (first (openai-java/image-binaries response))]
              (printf "Tokens:  %n%s%n" (openai-java/format-usage usage "  "))
              (io/spit (io/file "./image-1.png") image-1)
              (println "Image #1 saved to ./image-1.png")))
          """)
     :see-also '(
          "openai-java/client"
          "openai-java/edit-image"
          "openai-java/usage"
          "openai-java/image-binaries"
          "openai-java/image-urls") }

  generate-image [client model prompt & options]

  { :pre [(instance-of? :OpenAIClient client) (keyword? model) (string? prompt)] }

  (let [opts            (apply hash-map options)
        background      (:background opts)
        number          (:number opts)
        compression     (:compression opts)
        format          (:format opts)
        quality         (:quality opts) 
        size            (:size opts)
        style           (:style opts)
        response-format (:response-format opts)]
    (let [params (. :ImageGenerateParams :builder)]
      (. params :model (. :ImageModel model))
      (. params :prompt prompt)
      (when background (. params :background (. :ImageGenerateParams$Background background)))
      (when number (. params :n number))
      (when compression (. params :outputCompression compression))
      (when format (. params :outputFormat (. :ImageGenerateParams$OutputFormat format)))
      (when quality (. params :quality (. :ImageGenerateParams$Quality quality)))
      (when size (. params :size (. :ImageGenerateParams$Size :of size)))
      (when style (. params :style (. :ImageGenerateParams$Style style)))
      (when response-format (. params :responseFormat (. :ImageGenerateParams$ResponseFormat response-format)))

      (-> (. client :images) 
          (. :generate (. params :build))))))


(defn 
  ^{ :arglists '(
          "(edit-image client image mimetype name model prompt & options)" )
     :doc """
          Edits an image.

          ¶**Parameters**

          | [![width: 15%]] | [![width: 85%]] |
          | :client c   | A client.¶ Use `openai-java/client` to create a client |
          | :image i    | The image to edit. An `io/file`, a `bytebuf`, or a Java  `:InputStream` |
          | :mimetype m | The image's mimetype. E.g.:  `image/png`¶ |
          | :name n     | The image's name. E.g.:  `sea-otter.png`¶ |
          | :model m    | The model to use for image generation. One of \
                          `:DALL_E_2`, `:DALL_E_3`, or a GPT image model (`:GPT_IMAGE_1`, \
                          `:GPT_IMAGE_1_MINI`, `:GPT_IMAGE_1_5`, or `:GPT_IMAGE_2`). \
                          Defaults to `:DALL_E_2` unless a parameter specific to \
                          the GPT image models is used.|
          | :prompt p   | A text description of the desired image(s). The maximum \
                          length is 32000 characters for the GPT image models, 1000 \
                          characters for dall-e-2 and 4000 characters for dall-e-3. |


          ¶**Parameter «options»**

          | [![width: 15%]] | [![width: 85%]] |
          | :background b   | Allows to set transparency for the background of the \
                              generated image(s). This parameter is only supported \
                              for GPT image models that support transparent backgrounds. \
                              Must be one of transparent, opaque, or auto (default value). \
                              When `:AUTO` is used, the model will automatically determine \
                              the best background for the image.¶\
                              `:GPT-IMAGE-2` does not support transparent backgrounds. \
                              Requests with background set to transparent will return an \
                              error for these models; use opaque or auto instead.¶\
                              If transparent, the output format needs to support transparency, \
                              so it should be set to either `:PNG` (default value) or `:WEBP`. |
          | :number n       | The number of images to generate. Must be between 1 and 10. For \
                              `:DALL_E_3`, only `n=1` is supported.¶\
                              minimum: 1, maximum: 10 |
          | :compression c  | The compression level (0-100%) for the generated images. This \
                              parameter is only supported for the GPT image models with the \
                              `:WEBP` or `:JPEG` output formats, and defaults to 100. |
          | :format f       | The format in which the generated images are returned. \
                              This parameter is only supported for the GPT image models. \
                              Must be one of `:PNG`, `:JPEG`, or `:WEBP`.  |
          | :quality f      | The quality of the image that will be generated.¶\
                              \u00A0 • `:AUTO` (default value) will automatically select the \
                              best quality for the given model.¶\
                              \u00A0 • `:HIGH`, `:MEDIUM` and `:LOW` are supported for the \
                              GPT image models.¶\
                              \u00A0 • `:HD` and `:STANDARD` are supported for `:DALL_E_3`.¶\
                              \u00A0 • `:STANDARD`is the only option for `:DALL_E_2`. |
          | :size f         | The size of the generated images.¶\
                              For `:GPT_IMAGE_2`, arbitrary resolutions are supported as \
                              WIDTHxHEIGHT strings, for example `1536x864`. Width and height \
                              must both be divisible by 16 and the requested aspect ratio \
                              must be between 1:3 and 3:1. Resolutions above `2560x1440` \
                              are experimental, and the maximum supported resolution is \
                              `3840x2160`. The requested size must also satisfy the model’s \
                              current pixel and edge limits. The standard sizes `1024x1024`, \
                              `1536x1024`, and `1024x1536` are supported by the GPT image models; \
                              auto is supported for models that allow automatic sizing. \
                              For `:DALL_E_2`, use one of `256x256`, `512x512`, or `1024x1024`. \
                              For `:DALL_E_3`, use one of `1024x1024`, `1792x1024`, or `1024x1792`. |
          | :fidelity f     | Control how much effort the model will exert to match the style \
                              and features, especially facial features, of input images. \
                              This parameter is only supported for `:GPT-IMAGE-1` and \
                              `:GPT-IMAGE-1_5` and later models, unsupported for \
                              `:GPT-IMAGE-1_MINI`. Supports `:HIGH` and `:LOW`. Defaults \
                              to `:LOW`. |
          | :response-format f | The format in which generated images with `:DALL_E_2` \
                                 and `:DALL_E_3` are returned. Must be one of `:URL` or `:B64_JSON`. \
                                 URLs are only valid for 60 minutes after the image has been \
                                 generated. This parameter isn’t supported for the GPT image \
                                 models, which always return base64-encoded images.|

          Returns an OpenAI image response

          [OpenAI Image Prompting Guide](https://developers.openai.com/cookbook/examples/multimodal/image-gen-models-prompting-guide)
          """ 
     :examples '(
          """
          (do
            (load-module :openai-java)

            (let [client       (openai-java/client)
                  response-gen (openai-java/generate-image 
                                  client 
                                  :GPT_IMAGE_1_MINI
                                  "A cute baby sea otter"
                                  :format :PNG
                                  :number 1
                                  :size "1024x1024")
                  usage-gen    (openai-java/usage response-gen)
                  image-1-gen  (first (openai-java/image-binaries response-gen))]
              (printf "Tokens:  %n%s%n" (openai-java/format-usage usage-gen "  "))
              (io/spit (io/file "./sea-otter.png") image-1-gen)
              (println "Image #1 saved to ./sea-otter.png")

              (println)
              (println "Editing image...")
              (let [response-edt (openai-java/edit-image 
                                    client 
                                    (io/bytebuf-in-stream image-1-gen)
                                    "image/png"
                                    "sea-otter.png"
                                    :GPT_IMAGE_1_MINI
                                    "A cute baby sea otter wearing a beret"
                                    :format :PNG
                                    :number 1
                                    :quality :HIGH
                                    :size "1024x1024")
                    usage-edt    (openai-java/usage response-edt)
                    image-1-edt  (first (openai-java/image-binaries response-edt))]
                (printf "Tokens:  %n%s%n" (openai-java/format-usage usage-edt  "  "))
                (io/spit (io/file "./sea-otter-edited.png") image-1-edt)
                (println "Image #1 saved to ./sea-otter-edited.png"))))
          """)
     :see-also '(
          "openai-java/client"
          "openai-java/generate-image"
          "openai-java/usage"
          "openai-java/image-binaries"
          "openai-java/image-urls") }

  edit-image [client image mimetype name model prompt & options]

  { :pre [(instance-of? :OpenAIClient client) 
          (or (io/file? image) (bytebuf? image) (io/in-stream? image))
          (string? mimetype)
          (string? name)
          (keyword? model) 
          (string? prompt)] }

  (let [opts            (apply hash-map options)
        background      (:background opts)
        number          (:number opts)
        compression     (:compression opts)
        format          (:format opts)
        quality         (:quality opts) 
        size            (:size opts)
        fidelity        (:fidelity opts)
        response-format (:response-format opts)]
    (let [params (. :ImageEditParams :builder)]

      (. params :image (. :Multiparts :multipartField_EditImage image mimetype name))
      (. params :model (. :ImageModel model))
      (. params :prompt prompt)
      (when background (. params :background (. :ImageEditParams$Background background)))
      (when number (. params :n number))
      (when compression (. params :outputCompression compression))
      (when format (. params :outputFormat (. :ImageEditParams$OutputFormat format)))
      (when quality (. params :quality (. :ImageEditParams$Quality quality)))
      (when size (. params :size (. :ImageEditParams$Size :of size)))
      (when fidelity (. params :fidelity (. :ImageEditParams$InputFidelity fidelity)))
      (when response-format (. params :responseFormat (. :ImageEditParams$ResponseFormat response-format)))

      (-> (. client :images) 
          (. :edit (. params :build))))))


(defn
  ^{ :arglists '(
          "(image-binaries response)" )
     :doc """
          Returns a list of image binaries in the response.
          """
     :see-also '(
          "openai-java/generate-image"
          "openai-java/image-urls") }

  image-binaries [response]

  { :pre [(instance-of? :ImagesResponse response)] }
  
  (if-let [images (java-unwrap-optional (. response :data) (list))]
    (->> images
         (map #(decode-b64 (. % :b64Json)))
         (filter some?))))


(defn
  ^{ :arglists '(
          "(image-urls response)" )
     :doc """
          Returns a list of image URLs in the response.
          """
     :see-also '(
          "openai-java/generate-image"
          "openai-java/image-binaries") }

  image-urls [response]

  { :pre [(instance-of? :ImagesResponse response)] }
  
  (if-let [images  (java-unwrap-optional (. response :data) (list))]
    (->> images
         (map #(java-unwrap-optional (. % :url)))
         (filter some?))))


(defn- decode-b64 [b64]
  (if-let [base64 (if (java-optional? b64) (java-unwrap-optional b64) b64)]
    (str/decode-base64 base64)
    nil))



;; -----------------------------------------------------------------------------
;; AUDIO
;; -----------------------------------------------------------------------------

(defn 
  ^{ :arglists '(
          "(create-speech client model input & options)" )
     :doc """
          Generates audio from the input text.

          ¶**Parameters**

          | [![width: 15%]] | [![width: 85%]] |
          | :client c   | A client.¶ Use `openai-java/client` to create a client |
          | :model m    | The model to use for audio generation. One of \
                              `:TTS_1`, `:TTS_1_HD`, or a GPT image model \
                              (`:GPT_4O_MINI_TTS`). |
          | :input s    | The text to generate audio for. The maximum length is \
                          4096 characters. |


          ¶**Parameter «options»**

          | [![width: 15%]] | [![width: 85%]] |
          | :instructions s   | Control the voice of your generated audio with \
                                additional instructions. Does not work with `:TTS_1` \
                                or `:TTS_1_HD`.¶\
                                max length: 4096 characters¶\
                                You can prompt the model to control aspects of speech, \
                                including:¶\
                                \u00A0 • *Accent*¶\
                                \u00A0 • *Emotional range*¶\
                                \u00A0 • *Intonation*¶\
                                \u00A0 • *Impressions*¶\
                                \u00A0 • *Speed of speech*¶\
                                \u00A0 • *Tone*¶\
                                \u00A0 • *Whispering* |
          | :format f        | The audio format. Supported formats are `:MP3`, `:OPIS`, \
                               `:AAC`, `:FLAC`, `:WAV`, `:PCM`|
          | :voice v         | The voice (string) to use when generating the audio.¶\
                               High quality voices:¶\
                               \u00A0 • "marin" (en_US, female)¶\
                               \u00A0 • "cedar" (en_US, male)|

          Returns an `:InputStream` with the created audio
          """ 
     :examples '(
          """
          (do
            (load-module :openai-java)
            (let [client   (openai-java/client)
                  is       (openai-java/create-speech
                                client 
                                :GPT_4O_MINI_TTS
                                "Today is a wonderful day to build something people love!"
                                :format :MP3
                                :voice "cedar")]
              (->> (io/slurp-stream is :binary true)
                   (io/spit (io/file "./audio.mp3")))
              (println "Audio saved to ./audio.mp3")))
          """,
          """
          ;; MacOS only!!
          (do
            (load-module :openai-java)
            (let [client   (openai-java/client)
                  is       (openai-java/create-speech
                                client 
                                :GPT_4O_MINI_TTS
                                "Today is a wonderful day to build something people love!"
                                :format :MP3
                                :voice "cedar")]
              (let [audio-file (io/file "./audio.mp3")]
                (println "Downloading audio ...")
                (->> (io/slurp-stream is :binary true)
                     (io/spit audio-file))
                (println "Saved audio to" audio-file)
                (if (os-type? :mac-osx)
                  (do
                    (println "Playing audio ...")
                    (sh "afplay" (io/file-path audio-file))
                    nil)
                  (println "Playing audio supported on MacOS only!")))))
          """)
     :see-also '(
          "openai-java/client") }

  create-speech [client model input & options]

  { :pre [(instance-of? :OpenAIClient client) 
          (keyword? model) 
          (string? input)] }

  (let [opts            (apply hash-map options)
        instructions    (:instructions opts)
        format          (:format opts)
        voice           (:voice opts)]
    (let [params (. :SpeechCreateParams :builder)]
      (. params :model (. :SpeechModel model))
      (. params :input input)
      (when instructions (. params :instructions instructions))
      (when format (. params :responseFormat (. :SpeechCreateParams$ResponseFormat format)))
      (when voice (. params :voice voice))

      (-> (. client :audio)
          (. :speech)
          (. :create (. params :build))
          (. :body)))))


(defn 
  ^{ :arglists '(
          "(transcribe client model file & options)" )
     :doc """
          Transcribes audio from the input file.

          Returns a transcription object in json, diarized_json, or verbose_json 
          format, or a stream of transcript events.

          ¶**Parameters**

          | [![width: 15%]] | [![width: 85%]] |
          | :client c   | A client.¶ Use `openai-java/client` to create a client |
          | :model m    | The model to use for transcription. One of \
                              `:GTP_4O_TRANSCRIBE`, `:GTP_4O_MINI_TRANSCRIBE`, or a \
                              `:WHISPER_1`, or `:GTP_4O_TRANSCRIBE_DIARIZE` |
          | :file f     | The audio file object (not file name) to transcribe, in one \
                          of these formats: flac, mp3, mp4, mpeg, mpga, m4a, ogg, wav, \
                          or webm. |


          ¶**Parameter «options»**

          | [![width: 15%]] | [![width: 85%]] |
          | :language l          | The language of the input audio. Supplying the input \
                                   language in ISO-639-1 (e.g. "en", "de", "fr", "it", ...) \
                                   format will improve accuracy and latency.|
          | :prompt p            | An optional text to guide the model’s style or continue \
                                   a previous audio segment. The prompt should match the \
                                   audio language. This field is not supported when using \
                                   `:GTP_4O_TRANSCRIBE_DIARIZE`.|
          | :response-format f   | The format of the output, in one of these options: \
                                   `:JSON`, `:TEXT`, `:SRT`, `:VERBOSE_JSON`, `:VTT`, or \
                                   `:DIARIZED_JSON`. For `:GTP_4O_TRANSCRIBE` and \
                                   `:GTP_4O_MINI_TRANSCRIBE`, the only supported format is \
                                   `:JSON`. For `:GTP_4O_TRANSCRIBE_DIARIZE`, the supported \
                                   formats are `:JSON`, `:TEXT`, and `:DIARIZED_JSON`, with \
                                   `:DIARIZED_JSON` required to receive speaker annotations.|
          | :temperature t       | The sampling temperature, between 0.0 and 1.0. Higher \
                                   values like 0.8 will make the output more random, while \
                                   lower values like 0.2 will make it more focused and \
                                   deterministic. If set to 0, the model will use log \
                                   probability to automatically increase the temperature \
                                   until certain thresholds are hit.|

          Returns the audio transcription response.
          """ 
     :examples '(
          """
          (do
            (load-module :openai-java)
            (let [demo-file  (io/file "./audio.wav")
                  client     (openai-java/client)
                  is         (openai-java/create-speech
                                client 
                                :GPT_4O_MINI_TTS
                                "Today is a wonderful day to build something people love!"
                                :format :WAV
                                :voice "cedar")]
              (->> (io/slurp-stream is :binary true)
                   (io/spit demo-file))
              (println "Audio saved to" demo-file)
              
              (println "Transcribing" demo-file)
              (let [response  (openai-java/transcribe client
                                      :GPT_4O_TRANSCRIBE
                                      demo-file
                                      :language  "en"
                                      :temperature 0.1
                                      :response-format :TEXT)]
                (println "Transcription:")
                (println (openai-java/transcription-text response)))))
          """)
     :see-also '(
          "openai-java/transcription-text"
          "openai-java/usage"
          "openai-java/client") }

  transcribe [client model file & options]

  { :pre [(instance-of? :OpenAIClient client) 
          (keyword? model) 
          (or (io/file? file) (bytebuf? file) (io/in-stream? file))] }

  (let [opts                   (apply hash-map options)
        chunking-strategy      (:chunking-strategy opts)
        language               (:language opts)
        prompt                 (:prompt opts)
        response-format        (:response-format opts)
        temperature            (:temperature opts)]
    (let [params (. :TranscriptionCreateParams :builder)]
      (. params :model (. :AudioModel model))
      (. params :file (io/->path file))
      (when language (. params :language language))
      (when prompt (. params :prompt prompt))
      (when response-format (. params :responseFormat (. :AudioResponseFormat response-format)))
      (when temperature (. params :temperature temperature))
      (-> (. client :audio)
          (. :transcriptions)
          (. :create (. params :build))))))


(defn 
  ^{ :arglists '(
          "(transcription-text response)" )
     :doc """
          Returns the transcription text of a transcription response.
          """
     :see-also '(
          "openai-java/transcribe") }

  transcription-text [response]

  { :pre [(instance-of? :TranscriptionCreateResponse response) ] }

  (if-let [transcription (java-unwrap-optional (. response :transcription))]
    (. transcription :text)
    nil))



;; -----------------------------------------------------------------------------
;; Utils
;; -----------------------------------------------------------------------------

(defn 
  ^{ :arglists '(
          "(usage response)" )
     :doc """
          Returns the token usage statistics.

          E.g:
          ```
          { :input-tokens 11
            :output-tokens 8
            :output-tokens-detail { :reasoning-tokens 0 } 
            :total-tokens 19 } 
          ```
          """
     :see-also '(
          "openai-java/chat-completion"
          "openai-java/generate-image") }

  usage [response]

  { :pre [(or (instance-of? :ChatCompletionTraditionalResponse response)
              (instance-of? :TranscriptionCreateResponse response)
              (instance-of? :ImagesResponse response))] }
  
  (-<> (. :TokenUsage :of response)
       (. <> :toVncMap)))


(defn 
  ^{ :arglists '(
          "(version)" )
     :doc """
          Returns the OpenAI Java library version. E.g.: "4.32.0"
          """
     :examples '(
          """
          (do
            (load-module :openai-java)
            (openai-java/version))
          """ )
     :see-also '(
          "openai-java/client") }

  version []

  (->> (java-package-version :com.openai.client.OpenAIClient)
       (:implementation-version)))


(defn 
  ^{ :arglists '(
          "(format-usage usage)" )
     :doc """
          Formats a response's usage info to human readable multiline text.

          Usage token info:

          ```
          { :input-tokens 11
            :output-tokens 15
            :output-details  { :reasoning-tokens 0 }
            :total-tokens 26 }
          ```
          """
     :see-also '(
          "openai-java/chat-completion") }
  
  format-usage 
 
  ([usage]
    (format-usage usage nil nil))

  ([usage indent]
    (format-usage usage indent nil))

  ([usage indent title]
    { :pre [(map? usage) 
            (or (nil? indent) (string? indent))
            (or (nil? title) (string? title))] }
    (let [indent          (coalesce indent "")
          title           (str/trim-to-nil title)
          input-details   (format-usage-details (:input-details usage))
          output-details  (format-usage-details (:output-details usage))
          title-formatted (if (nil? title) "" (str/format "%s%n" title))]
      (str/format (str "%s"
                       "%sInput:  %5d%s%n"
                       "%sOutput: %5d%s%n"
                       "%sTotal:  %5d%n")
                  title-formatted
                  indent (:input-tokens usage)   input-details
                  indent (:output-tokens usage)  output-details 
                  indent (:total-tokens usage)))))

(defn- format-usage-details [io-usage]
  (let [detail-items    [ ["Reasoning" (:reasoning-tokens io-usage 0)]
                          ["Image"     (:image-tokens     io-usage 0)]
                          ["Audio"     (:audio-tokens     io-usage 0)]
                          ["Text"      (:text-tokens      io-usage 0)] ]
        effective-items (->> (filter #(pos? (second %)) detail-items)
                             (map #(str (first %) ": " (second %)))
                             (str/join ", "))]
    (if (empty? effective-items) "" (str "  (" effective-items ")"))))


(defn 
  ^{ :arglists '(
          "(models)" )
     :doc """
          Returns all supported OpenAI models
          """
     :examples '(
          """
          (do
            (load-module :openai-java)
            (openai-java/models))
          """)
     :see-also '(
          "openai-java/chat-completion") }

  models []
  
  (->> (. :ChatCompletionTraditionalRequest :models) ;; java.util.ArrayList
       (map keyword)))


(defn 
  ^{ :arglists '(
          "(play-sound is)" )
     :doc """
          Plays audio from an :InputStream
          """
     :examples '(
          """
          (do
            (load-module :openai-java)
            (openai-java/models))
          """)
     :see-also '(
        "openai-java/chat-completion") }

  play-sound [is]
  
  (let [data         (io/slurp-stream is :binary true)
        audio-stream (. :AudioSystem :getAudioInputStream (io/bytebuf-in-stream data))
        clip         (. :AudioSystem :getClip)]
    (. clip :open audio-stream)
    (. clip :start)))



;; -----------------------------------------------------------------------------
;; Function registry
;; -----------------------------------------------------------------------------

(defn
  ^{ :arglists '(
          "(create-function-registry)" )
     :doc """
          Create a function registry.
          """
     :examples '(
          """
          (do
            (load-module :openai-java)
  
            (defn get-weather [fnArgsJson] "sunny, 21°C")

            (let [registry (-> (openai-java/create-function-registry)
                               (openai-java/register-function "GetWeather"
                                                              get-weather))]
              ))
          """ )
     :see-also '(
          "openai-java/chat-completion"
          "openai-java/register-function") }

  create-function-registry []

  (. :RegistryFunctionDispatcher :new))


(defn
    ^{ :arglists '(
          "(registry name function)" )
     :doc """
          Register a function with the registry
          """
     :examples '(
          """
          (do
            (load-module :openai-java)
  
            (defn get-weather [fnArgsJson] "sunny, 21°C")

            (let [registry (-> (openai-java/create-function-registry)
                               (openai-java/register-function "GetWeather"
                                                              get-weather))]
              ))
          """ )
     :see-also '(
          "openai-java/chat-completion"
          "openai-java/create-function-registry") }

  register-function  [registry name function]

  { :pre [(instance-of? :RegistryFunctionDispatcher registry)
          (string? name)
          (fn? function)] }
  (. registry :register name (java/as-function function))
  registry)


;; -----------------------------------------------------------------------------
;; Internal Utils
;; -----------------------------------------------------------------------------

(defn- validate-libs-installed []
  (when-not (exists-class? :com.openai.client.OpenAIClient) 
    (throw (ex :VncException 
               (str "The OpenAI Java libraries are not available! \n\n"
                    "E.g.: Install the libraries in the REPL: \n"
                    "(do \n"
                    "  (load-module :openai-java-install) \n"
                    "  (openai-java-install/install :dir (repl/libs-dir) :silent false)) "))))
  true)

(defn filter-msgs [m]
  (if (sequential? m)
    (filter #(and (some? %) (string? %)) m)
    m))

(defn- openai-api-key-from-env []
  (system-env "OPENAI_API_KEY"))

(defn- openai-org-id-from-env [] 
  (system-env "OPENAI_ORG_ID"))

(defn- openai-proj-id-from-env [] 
  (system-env "OPENAI_PROJECT_ID"))

(defn- openai-base-url-from-env [] 
  (system-env "OPENAI_BASE_URL"))

