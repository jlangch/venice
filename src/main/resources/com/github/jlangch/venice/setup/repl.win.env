REM # ------------------------------------------------------------------------------
REM # Environment variables for windows operating systems
REM #
REM # This file will be 'sourced' by 'repl.bat' at REPL startup time. You can add
REM # as many environment variables you like.
REM # ------------------------------------------------------------------------------


REM # Modify to set JAVA_HOME explicitly, or comment to use system JAVA_HOME
REM set JAVA_HOME=

REM # Modify to add Java VM options (e.g.: -Xms1G -Xmx3G)
set JAVA_OPTS=-Xmx2G

REM # Uncomment and modify to set a loadpath for the REPL
REM set LOADPATH=

REM # Define a color mode {light, dark} for the REPL
set COLOR_MODE=dark

REM # If true switch the Windows terminal and Java to UTF-8
set UTF8_TERM=false


REM # OpenAI api key
set OPENAI_API_KEY=sk-123456789
set OPENAI_ORG_ID=
set OPENAI_PROJECT_ID=
