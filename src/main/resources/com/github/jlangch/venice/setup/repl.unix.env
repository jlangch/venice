# ------------------------------------------------------------------------------
# Environment variables for unix / linux operating systems
#
# This file will be 'sourced' by 'repl.sh' at REPL startup time. You can add
# as many environment variables you like.
# ------------------------------------------------------------------------------


# Modify to set JAVA_HOME explicitly, or comment to use system JAVA_HOME
# export JAVA_HOME=

# Modify to add Java VM options (e.g.: -Xms1G -Xmx3G)
export JAVA_OPTS=-Xmx4G

# Uncomment and modify to set a loadpath for the REPL
# export LOADPATH=

# Uncomment to enable Java debugger
# export DEBUG_OPTS="-Xdebug -Xrunjdwp:transport=dt_socket,address=1044,server=y,suspend=n"



# OpenAI api key
export OPENAI_API_KEY=sk-123456789
