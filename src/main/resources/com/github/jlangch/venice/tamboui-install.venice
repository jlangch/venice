;;;; Install TamboUI libraries: 
;;;;
;;;;   (load-module :tamboui-install)
;;;;   (tamboui-install/install :dir (repl/libs-dir) :silent false)
;;;;
;;;; Note: This not a package manager. The module provides functions to
;;;;       download Java libraries to a directory. 


;;;; TamboUI documentation: 
;;;;
;;;; https://tamboui.dev/
;;;; https://tamboui.dev/docs/main/index.html
;;;; https://tamboui.dev/docs/main/demos-widgets.html
;;;;
;;;; GitHub:  https://github.com/tamboui/tamboui


(ns tamboui-install)

(load-module :installer)


(defn libraries []
  [ "dev.tamboui:tamboui-core:0.3.0"
    "dev.tamboui:tamboui-css:0.3.0"
    "dev.tamboui:tamboui-jline3-backend:0.3.0"
    "dev.tamboui:tamboui-markdown:0.3.0"
    "dev.tamboui:tamboui-markdown-toolkit:0.3.0"
    "dev.tamboui:tamboui-toolkit:0.3.0"
    "dev.tamboui:tamboui-tui:0.3.0"
    "dev.tamboui:tamboui-widgets:0.3.0" ])


(defn dependencies []
  (maven/dependencies (libraries) :scope :runtime))


(defn
  ^{ :arglists '("(install options*)")
     :doc
       """
       Install the Java 3rd party libraries for the OpenAI-Java module.

       Options:

       | :dir path             | download dir, defaults to "." |
       | :silent {true,false}  | if silent is true does not show a progress \
                                 bar, defaults to true |
       """
     :examples '(
       """
       (do
         (load-module :tamboui-install)
         (tamboui-install/install :dir (repl/libs-dir) :silent false))
       """) }

  install [ & options]

  (apply installer/install (libraries) options))

